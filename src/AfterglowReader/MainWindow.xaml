<Window x:Class="AfterglowReader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:AfterglowReader"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="余光阅读器"
        Icon="/AfterglowReader;component/Assets/afterglow.ico"
        Height="520"
        Width="720"
        MinHeight="240"
        MinWidth="360"
        Background="#F7F3EA"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowActivated="True"
        ShowInTaskbar="True"
        Topmost="False"
        Opacity="1"
        WindowStartupLocation="CenterScreen">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="8"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>
    <Grid Background="#F7F3EA" ClipToBounds="True">
        <wv2:WebView2 x:Name="ReaderView" />

        <Grid Background="Transparent" Panel.ZIndex="2">
            <primitives:Thumb x:Name="DragThumb"
                              Height="28"
                              VerticalAlignment="Top"
                              HorizontalAlignment="Stretch"
                              Background="Transparent"
                              DragDelta="DragThumb_DragDelta" />
            <primitives:Thumb x:Name="TopResizeThumb"
                              Height="6"
                              VerticalAlignment="Top"
                              HorizontalAlignment="Stretch"
                              Cursor="SizeNS"
                              Background="Transparent"
                              DragDelta="TopResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="LeftResizeThumb"
                              Width="6"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Stretch"
                              Cursor="SizeWE"
                              Background="Transparent"
                              DragDelta="LeftResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="RightResizeThumb"
                              Width="6"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Stretch"
                              Cursor="SizeWE"
                              Background="Transparent"
                              DragDelta="RightResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="BottomResizeThumb"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Bottom"
                              Cursor="SizeNS"
                              Background="Transparent"
                              DragDelta="BottomResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="TopLeftResizeThumb"
                              Width="10"
                              Height="10"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Top"
                              Cursor="SizeNWSE"
                              Background="Transparent"
                              DragDelta="TopLeftResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="TopRightResizeThumb"
                              Width="10"
                              Height="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"
                              Cursor="SizeNESW"
                              Background="Transparent"
                              DragDelta="TopRightResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="BottomLeftResizeThumb"
                              Width="10"
                              Height="10"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Bottom"
                              Cursor="SizeNESW"
                              Background="Transparent"
                              DragDelta="BottomLeftResizeThumb_DragDelta" />
            <primitives:Thumb x:Name="BottomRightResizeThumb"
                              Width="10"
                              Height="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Bottom"
                              Cursor="SizeNWSE"
                              Background="Transparent"
                              DragDelta="BottomRightResizeThumb_DragDelta" />
        </Grid>

        <Border x:Name="StatusPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="24,12,0,0"
                Padding="10,6"
                Background="#DD2A2521"
                CornerRadius="5"
                IsHitTestVisible="False"
                Panel.ZIndex="3">
            <TextBlock x:Name="StatusText"
                       Foreground="White"
                       FontSize="12"
                       Text="正在初始化 WebView2…" />
        </Border>
    </Grid>
</Window>
